{
  "appName": "AI App",
  "description": "Een eenvoudige SaaS-app waarmee gebruikers AI-taken kunnen beheren en uitvoeren. Gebruikers kunnen zich registreren, inloggen, hun profiel beheren en een lijst van AI-taken bekijken en toevoegen.",
  "tier": "medium",
  "stack": {
    "framework": "Next.js 14 App Router",
    "language": "TypeScript",
    "styling": [
      "Tailwind CSS",
      "shadcn/ui"
    ],
    "api": [
      "Next.js Route Handlers (app/api)"
    ],
    "notes": "Alle UI-componenten worden opgebouwd met shadcn/ui en gestyled met Tailwind CSS. API-routes worden afgehandeld via Next.js route handlers."
  },
  "domains": [
    {
      "name": "User",
      "description": "Beheer van gebruikersaccounts en authenticatie.",
      "entities": [
        {
          "name": "User",
          "description": "Een geregistreerde gebruiker van de app.",
          "fields": [
            {
              "name": "id",
              "type": "string",
              "required": true,
              "description": "Unieke identifier voor de gebruiker."
            },
            {
              "name": "email",
              "type": "string",
              "required": true,
              "description": "E-mailadres van de gebruiker."
            },
            {
              "name": "passwordHash",
              "type": "string",
              "required": true,
              "description": "Gehasht wachtwoord van de gebruiker."
            },
            {
              "name": "name",
              "type": "string",
              "required": false,
              "description": "Naam van de gebruiker."
            },
            {
              "name": "createdAt",
              "type": "Date",
              "required": true,
              "description": "Aanmaakdatum van het account."
            }
          ]
        }
      ]
    },
    {
      "name": "AITask",
      "description": "Beheer van AI-taken die door gebruikers worden aangemaakt.",
      "entities": [
        {
          "name": "AITask",
          "description": "Een AI-taak die door een gebruiker is aangemaakt.",
          "fields": [
            {
              "name": "id",
              "type": "string",
              "required": true,
              "description": "Unieke identifier voor de taak."
            },
            {
              "name": "userId",
              "type": "string",
              "required": true,
              "description": "ID van de gebruiker die de taak heeft aangemaakt."
            },
            {
              "name": "title",
              "type": "string",
              "required": true,
              "description": "Titel van de AI-taak."
            },
            {
              "name": "status",
              "type": "string",
              "required": true,
              "description": "Status van de taak (bijv. pending, running, completed)."
            },
            {
              "name": "createdAt",
              "type": "Date",
              "required": true,
              "description": "Aanmaakdatum van de taak."
            }
          ]
        }
      ]
    }
  ],
  "routes": [
    {
      "path": "/",
      "type": "page",
      "description": "Homepagina met overzicht en call-to-action.",
      "file": "app/page.tsx",
      "layout": "app/layout.tsx"
    },
    {
      "path": "/login",
      "type": "page",
      "description": "Loginpagina voor gebruikers.",
      "file": "app/login/page.tsx",
      "layout": "app/layout.tsx"
    },
    {
      "path": "/register",
      "type": "page",
      "description": "Registratiepagina voor nieuwe gebruikers.",
      "file": "app/register/page.tsx",
      "layout": "app/layout.tsx"
    },
    {
      "path": "/dashboard",
      "type": "layout",
      "description": "Dashboardlayout voor ingelogde gebruikers.",
      "file": "app/dashboard/layout.tsx",
      "layout": "app/layout.tsx"
    },
    {
      "path": "/dashboard",
      "type": "page",
      "description": "Dashboard-overzicht met AI-takenlijst.",
      "file": "app/dashboard/page.tsx",
      "layout": "app/dashboard/layout.tsx"
    },
    {
      "path": "/dashboard/profile",
      "type": "page",
      "description": "Profielpagina voor de gebruiker.",
      "file": "app/dashboard/profile/page.tsx",
      "layout": "app/dashboard/layout.tsx"
    },
    {
      "path": "/dashboard/tasks",
      "type": "page",
      "description": "Overzicht van AI-taken van de gebruiker.",
      "file": "app/dashboard/tasks/page.tsx",
      "layout": "app/dashboard/layout.tsx"
    },
    {
      "path": "/dashboard/tasks/new",
      "type": "page",
      "description": "Pagina om een nieuwe AI-taak aan te maken.",
      "file": "app/dashboard/tasks/new/page.tsx",
      "layout": "app/dashboard/layout.tsx"
    }
  ],
  "apiRoutes": [
    {
      "path": "/api/auth/register",
      "methods": [
        "POST"
      ],
      "description": "Registreer een nieuwe gebruiker."
    },
    {
      "path": "/api/auth/login",
      "methods": [
        "POST"
      ],
      "description": "Log een gebruiker in."
    },
    {
      "path": "/api/auth/logout",
      "methods": [
        "POST"
      ],
      "description": "Log een gebruiker uit."
    },
    {
      "path": "/api/user/profile",
      "methods": [
        "GET",
        "PUT"
      ],
      "description": "Haal profielgegevens op of werk deze bij."
    },
    {
      "path": "/api/tasks",
      "methods": [
        "GET",
        "POST"
      ],
      "description": "Haal alle AI-taken van de gebruiker op of maak een nieuwe taak aan."
    },
    {
      "path": "/api/tasks/[id]",
      "methods": [
        "GET",
        "PUT",
        "DELETE"
      ],
      "description": "Haal details van een taak op, werk deze bij of verwijder de taak."
    }
  ],
  "components": [
    {
      "name": "Navbar",
      "description": "Navigatiebalk bovenaan de app.",
      "file": "components/Navbar.tsx",
      "usedOn": [
        "/",
        "/login",
        "/register",
        "/dashboard",
        "/dashboard/profile",
        "/dashboard/tasks",
        "/dashboard/tasks/new"
      ]
    },
    {
      "name": "TaskList",
      "description": "Lijstweergave van AI-taken.",
      "file": "components/TaskList.tsx",
      "usedOn": [
        "/dashboard",
        "/dashboard/tasks"
      ]
    },
    {
      "name": "TaskForm",
      "description": "Formulier om een nieuwe AI-taak aan te maken.",
      "file": "components/TaskForm.tsx",
      "usedOn": [
        "/dashboard/tasks/new"
      ]
    },
    {
      "name": "ProfileForm",
      "description": "Formulier om gebruikersprofiel te bewerken.",
      "file": "components/ProfileForm.tsx",
      "usedOn": [
        "/dashboard/profile"
      ]
    },
    {
      "name": "LoginForm",
      "description": "Formulier voor gebruikerslogin.",
      "file": "components/LoginForm.tsx",
      "usedOn": [
        "/login"
      ]
    },
    {
      "name": "RegisterForm",
      "description": "Formulier voor gebruikersregistratie.",
      "file": "components/RegisterForm.tsx",
      "usedOn": [
        "/register"
      ]
    }
  ],
  "stateManagement": {
    "strategy": "React Context + useState voor globale auth-state en gebruikersdata.",
    "notes": "Authenticatie- en gebruikersgegevens worden in een AuthContext opgeslagen. Voor lokale component state wordt useState gebruikt."
  },
  "dataLayer": {
    "strategy": "In-memory store (singleton pattern) voor gebruikers en taken.",
    "notes": "Voor MVP wordt data in-memory opgeslagen in een singleton object. In productie kan dit eenvoudig vervangen worden door een database."
  }
}