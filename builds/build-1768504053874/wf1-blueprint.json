{
  "appName": "AI App",
  "description": "Een eenvoudige SaaS-app waarmee gebruikers AI-taken kunnen beheren. Gebruikers kunnen zich registreren, inloggen, hun profiel beheren en een lijst van AI-taken bekijken en aanmaken.",
  "tier": "medium",
  "stack": {
    "framework": "Next.js 14 App Router",
    "language": "TypeScript",
    "styling": [
      "Tailwind CSS",
      "shadcn/ui"
    ],
    "api": [
      "Next.js Route Handlers (app/api)"
    ],
    "notes": "Alle UI wordt gebouwd met shadcn/ui en Tailwind CSS. API-routes worden afgehandeld via app/api/* handlers. Data wordt in-memory opgeslagen voor MVP."
  },
  "domains": [
    {
      "name": "User",
      "description": "Beheer van gebruikersaccounts en authenticatie.",
      "entities": [
        {
          "name": "User",
          "description": "Een geregistreerde gebruiker van de app.",
          "fields": [
            {
              "name": "id",
              "type": "string",
              "required": true,
              "description": "Unieke identifier voor de gebruiker."
            },
            {
              "name": "email",
              "type": "string",
              "required": true,
              "description": "E-mailadres van de gebruiker."
            },
            {
              "name": "name",
              "type": "string",
              "required": false,
              "description": "Naam van de gebruiker."
            },
            {
              "name": "passwordHash",
              "type": "string",
              "required": true,
              "description": "Gehasht wachtwoord voor authenticatie."
            }
          ]
        }
      ]
    },
    {
      "name": "AITask",
      "description": "AI-taken die door gebruikers worden aangemaakt en beheerd.",
      "entities": [
        {
          "name": "AITask",
          "description": "Een AI-taak aangemaakt door een gebruiker.",
          "fields": [
            {
              "name": "id",
              "type": "string",
              "required": true,
              "description": "Unieke identifier voor de taak."
            },
            {
              "name": "userId",
              "type": "string",
              "required": true,
              "description": "ID van de gebruiker die de taak heeft aangemaakt."
            },
            {
              "name": "title",
              "type": "string",
              "required": true,
              "description": "Titel van de AI-taak."
            },
            {
              "name": "description",
              "type": "string",
              "required": false,
              "description": "Beschrijving van de AI-taak."
            },
            {
              "name": "createdAt",
              "type": "string",
              "required": true,
              "description": "Aanmaakdatum van de taak (ISO string)."
            }
          ]
        }
      ]
    }
  ],
  "routes": [
    {
      "path": "/",
      "type": "page",
      "description": "Homepagina met uitleg en call-to-action.",
      "file": "app/page.tsx",
      "layout": "app/layout.tsx"
    },
    {
      "path": "/login",
      "type": "page",
      "description": "Loginpagina voor bestaande gebruikers.",
      "file": "app/login/page.tsx",
      "layout": "app/layout.tsx"
    },
    {
      "path": "/register",
      "type": "page",
      "description": "Registratiepagina voor nieuwe gebruikers.",
      "file": "app/register/page.tsx",
      "layout": "app/layout.tsx"
    },
    {
      "path": "/dashboard",
      "type": "layout",
      "description": "Dashboardlayout voor ingelogde gebruikers.",
      "file": "app/dashboard/layout.tsx",
      "layout": "app/layout.tsx"
    },
    {
      "path": "/dashboard",
      "type": "page",
      "description": "Overzicht van AI-taken van de gebruiker.",
      "file": "app/dashboard/page.tsx",
      "layout": "app/dashboard/layout.tsx"
    },
    {
      "path": "/dashboard/profile",
      "type": "page",
      "description": "Profielpagina van de gebruiker.",
      "file": "app/dashboard/profile/page.tsx",
      "layout": "app/dashboard/layout.tsx"
    },
    {
      "path": "/dashboard/tasks/new",
      "type": "page",
      "description": "Pagina om een nieuwe AI-taak aan te maken.",
      "file": "app/dashboard/tasks/new/page.tsx",
      "layout": "app/dashboard/layout.tsx"
    }
  ],
  "apiRoutes": [
    {
      "path": "/api/auth/login",
      "methods": [
        "POST"
      ],
      "description": "Authenticatie van gebruikers (inloggen)."
    },
    {
      "path": "/api/auth/register",
      "methods": [
        "POST"
      ],
      "description": "Registratie van nieuwe gebruikers."
    },
    {
      "path": "/api/auth/me",
      "methods": [
        "GET"
      ],
      "description": "Ophalen van huidige gebruikersinformatie (auth check)."
    },
    {
      "path": "/api/tasks",
      "methods": [
        "GET",
        "POST"
      ],
      "description": "Ophalen en aanmaken van AI-taken voor de ingelogde gebruiker."
    },
    {
      "path": "/api/tasks/[id]",
      "methods": [
        "GET",
        "DELETE"
      ],
      "description": "Ophalen of verwijderen van een specifieke AI-taak."
    },
    {
      "path": "/api/profile",
      "methods": [
        "GET",
        "PUT"
      ],
      "description": "Ophalen en bijwerken van gebruikersprofiel."
    }
  ],
  "components": [
    {
      "name": "Navbar",
      "description": "Navigatiebalk bovenaan de app.",
      "file": "components/Navbar.tsx",
      "usedOn": [
        "app/layout.tsx",
        "app/dashboard/layout.tsx"
      ]
    },
    {
      "name": "AuthForm",
      "description": "Formulier voor login en registratie.",
      "file": "components/AuthForm.tsx",
      "usedOn": [
        "app/login/page.tsx",
        "app/register/page.tsx"
      ]
    },
    {
      "name": "TaskList",
      "description": "Toont een lijst van AI-taken.",
      "file": "components/TaskList.tsx",
      "usedOn": [
        "app/dashboard/page.tsx"
      ]
    },
    {
      "name": "TaskForm",
      "description": "Formulier om een nieuwe AI-taak aan te maken.",
      "file": "components/TaskForm.tsx",
      "usedOn": [
        "app/dashboard/tasks/new/page.tsx"
      ]
    },
    {
      "name": "ProfileForm",
      "description": "Formulier om gebruikersprofiel te bewerken.",
      "file": "components/ProfileForm.tsx",
      "usedOn": [
        "app/dashboard/profile/page.tsx"
      ]
    }
  ],
  "stateManagement": {
    "strategy": "React Context voor authenticatie en gebruikersdata, lokale component state voor formulieren.",
    "notes": "Authenticatiegegevens worden opgeslagen in een contextprovider. Voor eenvoudige state (formulieren, UI) wordt useState gebruikt."
  },
  "dataLayer": {
    "strategy": "In-memory store (singleton pattern) voor gebruikers en taken.",
    "notes": "Voor MVP wordt data in-memory opgeslagen in het serverproces. In productie kan dit eenvoudig vervangen worden door een database."
  }
}