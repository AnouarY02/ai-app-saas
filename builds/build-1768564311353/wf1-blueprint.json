{
  "appName": "AI App",
  "description": "Een eenvoudige SaaS-app waarmee gebruikers AI-taken kunnen beheren. Gebruikers kunnen zich registreren, inloggen en hun eigen AI-taken aanmaken, bekijken en verwijderen. De app bevat een dashboard en een profielpagina.",
  "tier": "medium",
  "stack": {
    "framework": "Next.js 14 App Router",
    "language": "TypeScript",
    "styling": [
      "Tailwind CSS",
      "shadcn/ui"
    ],
    "api": [
      "Next.js Route Handlers (app/api)"
    ],
    "notes": "Alle UI wordt opgebouwd met shadcn/ui en Tailwind. API-routes worden afgehandeld via app/api/* route handlers. Data wordt in-memory opgeslagen voor MVP."
  },
  "domains": [
    {
      "name": "User",
      "description": "Beheert gebruikersaccounts en authenticatie.",
      "entities": [
        {
          "name": "User",
          "description": "Een geregistreerde gebruiker van de app.",
          "fields": [
            {
              "name": "id",
              "type": "string",
              "required": true,
              "description": "Unieke identifier voor de gebruiker."
            },
            {
              "name": "email",
              "type": "string",
              "required": true,
              "description": "E-mailadres van de gebruiker."
            },
            {
              "name": "passwordHash",
              "type": "string",
              "required": true,
              "description": "Gehasht wachtwoord van de gebruiker."
            },
            {
              "name": "name",
              "type": "string",
              "required": false,
              "description": "Naam van de gebruiker."
            }
          ]
        }
      ]
    },
    {
      "name": "AITask",
      "description": "Beheert AI-taken die door gebruikers zijn aangemaakt.",
      "entities": [
        {
          "name": "AITask",
          "description": "Een AI-taak die door een gebruiker is aangemaakt.",
          "fields": [
            {
              "name": "id",
              "type": "string",
              "required": true,
              "description": "Unieke identifier voor de AI-taak."
            },
            {
              "name": "userId",
              "type": "string",
              "required": true,
              "description": "ID van de gebruiker die de taak heeft aangemaakt."
            },
            {
              "name": "title",
              "type": "string",
              "required": true,
              "description": "Titel van de AI-taak."
            },
            {
              "name": "description",
              "type": "string",
              "required": false,
              "description": "Beschrijving van de AI-taak."
            },
            {
              "name": "createdAt",
              "type": "string",
              "required": true,
              "description": "Aanmaakdatum van de taak (ISO string)."
            }
          ]
        }
      ]
    }
  ],
  "routes": [
    {
      "path": "/",
      "type": "page",
      "description": "Landingpagina met uitleg en call-to-action.",
      "file": "app/page.tsx",
      "layout": "app/layout.tsx"
    },
    {
      "path": "/login",
      "type": "page",
      "description": "Loginpagina voor bestaande gebruikers.",
      "file": "app/login/page.tsx",
      "layout": "app/layout.tsx"
    },
    {
      "path": "/register",
      "type": "page",
      "description": "Registratiepagina voor nieuwe gebruikers.",
      "file": "app/register/page.tsx",
      "layout": "app/layout.tsx"
    },
    {
      "path": "/dashboard",
      "type": "page",
      "description": "Dashboard met overzicht van AI-taken van de gebruiker.",
      "file": "app/dashboard/page.tsx",
      "layout": "app/(auth)/layout.tsx"
    },
    {
      "path": "/profile",
      "type": "page",
      "description": "Profielpagina van de gebruiker.",
      "file": "app/profile/page.tsx",
      "layout": "app/(auth)/layout.tsx"
    },
    {
      "path": "/dashboard",
      "type": "layout",
      "description": "Layout voor alle dashboard-gerelateerde pagina's.",
      "file": "app/(auth)/layout.tsx",
      "layout": "app/layout.tsx"
    },
    {
      "path": "/",
      "type": "layout",
      "description": "Hoofdlayout met navigatie en globale styling.",
      "file": "app/layout.tsx",
      "layout": null
    }
  ],
  "apiRoutes": [
    {
      "path": "/api/auth/register",
      "methods": [
        "POST"
      ],
      "description": "Registreert een nieuwe gebruiker."
    },
    {
      "path": "/api/auth/login",
      "methods": [
        "POST"
      ],
      "description": "Logt een gebruiker in en geeft een sessietoken terug."
    },
    {
      "path": "/api/auth/logout",
      "methods": [
        "POST"
      ],
      "description": "Logt de gebruiker uit en vernietigt de sessie."
    },
    {
      "path": "/api/aitasks",
      "methods": [
        "GET",
        "POST"
      ],
      "description": "Ophalen van alle AI-taken van de gebruiker (GET) of een nieuwe taak aanmaken (POST)."
    },
    {
      "path": "/api/aitasks/[id]",
      "methods": [
        "GET",
        "DELETE"
      ],
      "description": "Ophalen van een specifieke AI-taak (GET) of verwijderen (DELETE)."
    },
    {
      "path": "/api/user",
      "methods": [
        "GET"
      ],
      "description": "Ophalen van gebruikersprofielgegevens."
    }
  ],
  "components": [
    {
      "name": "Navbar",
      "description": "Navigatiebalk bovenaan de app.",
      "file": "components/Navbar.tsx",
      "usedOn": [
        "app/layout.tsx",
        "app/(auth)/layout.tsx"
      ]
    },
    {
      "name": "AuthForm",
      "description": "Formulier voor login en registratie.",
      "file": "components/AuthForm.tsx",
      "usedOn": [
        "app/login/page.tsx",
        "app/register/page.tsx"
      ]
    },
    {
      "name": "AITaskList",
      "description": "Lijstweergave van AI-taken.",
      "file": "components/AITaskList.tsx",
      "usedOn": [
        "app/dashboard/page.tsx"
      ]
    },
    {
      "name": "AITaskCard",
      "description": "Kaartweergave van een enkele AI-taak.",
      "file": "components/AITaskCard.tsx",
      "usedOn": [
        "components/AITaskList.tsx"
      ]
    },
    {
      "name": "AITaskForm",
      "description": "Formulier om een nieuwe AI-taak aan te maken.",
      "file": "components/AITaskForm.tsx",
      "usedOn": [
        "app/dashboard/page.tsx"
      ]
    },
    {
      "name": "ProfileForm",
      "description": "Formulier om gebruikersprofiel te bekijken en te bewerken.",
      "file": "components/ProfileForm.tsx",
      "usedOn": [
        "app/profile/page.tsx"
      ]
    }
  ],
  "stateManagement": {
    "strategy": "React Server Components (RSC) voor datafetching, client-side state via useState/useContext waar nodig.",
    "notes": "Authenticatie-status wordt bewaard in cookies/sessies. Kleine lokale state in componenten, geen externe state library nodig voor MVP."
  },
  "dataLayer": {
    "strategy": "In-memory store (singleton pattern) op server voor gebruikers en AI-taken.",
    "notes": "Voor MVP wordt data niet persistent opgeslagen. In een productieomgeving kan eenvoudig een database worden aangesloten."
  }
}