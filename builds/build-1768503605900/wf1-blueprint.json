{
  "appName": "AI App",
  "description": "Een eenvoudige SaaS-app waarmee gebruikers AI-taken kunnen beheren en uitvoeren. Gebruikers kunnen zich registreren, inloggen, hun profiel beheren en een lijst van AI-taken bekijken en uitvoeren. De app is geschikt als basis voor verdere AI-functionaliteit.",
  "tier": "medium",
  "stack": {
    "framework": "Next.js 14 App Router",
    "language": "TypeScript",
    "styling": [
      "Tailwind CSS",
      "shadcn/ui"
    ],
    "api": [
      "Next.js Route Handlers (app/api)"
    ],
    "notes": "Volledig server-side rendered waar mogelijk, client-side voor interactieve delen. Styling via Tailwind en shadcn/ui. Authentificatie via eenvoudige session store."
  },
  "domains": [
    {
      "name": "User",
      "description": "Beheer van gebruikersaccounts en authenticatie.",
      "entities": [
        {
          "name": "User",
          "description": "Een geregistreerde gebruiker van de app.",
          "fields": [
            {
              "name": "id",
              "type": "string",
              "required": true,
              "description": "Unieke identifier voor de gebruiker."
            },
            {
              "name": "email",
              "type": "string",
              "required": true,
              "description": "E-mailadres van de gebruiker."
            },
            {
              "name": "passwordHash",
              "type": "string",
              "required": true,
              "description": "Gehasht wachtwoord van de gebruiker."
            },
            {
              "name": "name",
              "type": "string",
              "required": false,
              "description": "Naam van de gebruiker."
            },
            {
              "name": "createdAt",
              "type": "Date",
              "required": true,
              "description": "Datum van registratie."
            }
          ]
        },
        {
          "name": "Session",
          "description": "Actieve sessie van een gebruiker.",
          "fields": [
            {
              "name": "sessionId",
              "type": "string",
              "required": true,
              "description": "Unieke sessie-ID."
            },
            {
              "name": "userId",
              "type": "string",
              "required": true,
              "description": "ID van de gebruiker."
            },
            {
              "name": "expiresAt",
              "type": "Date",
              "required": true,
              "description": "Verloopdatum van de sessie."
            }
          ]
        }
      ]
    },
    {
      "name": "AITask",
      "description": "Beheer van AI-taken die door gebruikers kunnen worden uitgevoerd.",
      "entities": [
        {
          "name": "AITask",
          "description": "Een AI-taak die door een gebruiker kan worden uitgevoerd.",
          "fields": [
            {
              "name": "id",
              "type": "string",
              "required": true,
              "description": "Unieke identifier voor de taak."
            },
            {
              "name": "userId",
              "type": "string",
              "required": true,
              "description": "ID van de gebruiker die de taak heeft aangemaakt."
            },
            {
              "name": "title",
              "type": "string",
              "required": true,
              "description": "Titel van de AI-taak."
            },
            {
              "name": "status",
              "type": "string",
              "required": true,
              "description": "Status van de taak (pending, running, completed, failed)."
            },
            {
              "name": "result",
              "type": "string",
              "required": false,
              "description": "Resultaat van de AI-taak (optioneel)."
            },
            {
              "name": "createdAt",
              "type": "Date",
              "required": true,
              "description": "Aanmaakdatum van de taak."
            }
          ]
        }
      ]
    }
  ],
  "routes": [
    {
      "path": "/",
      "type": "page",
      "description": "Publieke homepage met uitleg en login/register CTA.",
      "file": "app/page.tsx",
      "layout": "app/layout.tsx"
    },
    {
      "path": "/login",
      "type": "page",
      "description": "Loginpagina voor bestaande gebruikers.",
      "file": "app/login/page.tsx",
      "layout": "app/layout.tsx"
    },
    {
      "path": "/register",
      "type": "page",
      "description": "Registratiepagina voor nieuwe gebruikers.",
      "file": "app/register/page.tsx",
      "layout": "app/layout.tsx"
    },
    {
      "path": "/dashboard",
      "type": "layout",
      "description": "Dashboardlayout voor ingelogde gebruikers.",
      "file": "app/dashboard/layout.tsx",
      "layout": "app/layout.tsx"
    },
    {
      "path": "/dashboard",
      "type": "page",
      "description": "Overzicht van AI-taken van de gebruiker.",
      "file": "app/dashboard/page.tsx",
      "layout": "app/dashboard/layout.tsx"
    },
    {
      "path": "/dashboard/profile",
      "type": "page",
      "description": "Profielpagina van de gebruiker.",
      "file": "app/dashboard/profile/page.tsx",
      "layout": "app/dashboard/layout.tsx"
    },
    {
      "path": "/dashboard/tasks",
      "type": "page",
      "description": "Lijst van AI-taken van de gebruiker.",
      "file": "app/dashboard/tasks/page.tsx",
      "layout": "app/dashboard/layout.tsx"
    },
    {
      "path": "/dashboard/tasks/[id]",
      "type": "page",
      "description": "Detailpagina van een specifieke AI-taak.",
      "file": "app/dashboard/tasks/[id]/page.tsx",
      "layout": "app/dashboard/layout.tsx"
    }
  ],
  "apiRoutes": [
    {
      "path": "/api/auth/register",
      "methods": [
        "POST"
      ],
      "description": "Registreer een nieuwe gebruiker."
    },
    {
      "path": "/api/auth/login",
      "methods": [
        "POST"
      ],
      "description": "Log een gebruiker in en maak een sessie aan."
    },
    {
      "path": "/api/auth/logout",
      "methods": [
        "POST"
      ],
      "description": "Log een gebruiker uit en vernietig de sessie."
    },
    {
      "path": "/api/user/me",
      "methods": [
        "GET",
        "PATCH"
      ],
      "description": "Haal profielgegevens op of werk deze bij."
    },
    {
      "path": "/api/tasks",
      "methods": [
        "GET",
        "POST"
      ],
      "description": "Haal alle AI-taken van de gebruiker op of maak een nieuwe taak aan."
    },
    {
      "path": "/api/tasks/[id]",
      "methods": [
        "GET",
        "PATCH",
        "DELETE"
      ],
      "description": "Haal details van een taak op, werk deze bij of verwijder deze."
    }
  ],
  "components": [
    {
      "name": "Navbar",
      "description": "Navigatiebalk voor de hele app.",
      "file": "components/Navbar.tsx",
      "usedOn": [
        "app/layout.tsx",
        "app/dashboard/layout.tsx"
      ]
    },
    {
      "name": "AuthForm",
      "description": "Formulier voor login en registratie.",
      "file": "components/AuthForm.tsx",
      "usedOn": [
        "app/login/page.tsx",
        "app/register/page.tsx"
      ]
    },
    {
      "name": "TaskList",
      "description": "Lijstweergave van AI-taken.",
      "file": "components/TaskList.tsx",
      "usedOn": [
        "app/dashboard/page.tsx",
        "app/dashboard/tasks/page.tsx"
      ]
    },
    {
      "name": "TaskDetail",
      "description": "Detailweergave van een AI-taak.",
      "file": "components/TaskDetail.tsx",
      "usedOn": [
        "app/dashboard/tasks/[id]/page.tsx"
      ]
    },
    {
      "name": "ProfileForm",
      "description": "Formulier om gebruikersprofiel te bewerken.",
      "file": "components/ProfileForm.tsx",
      "usedOn": [
        "app/dashboard/profile/page.tsx"
      ]
    },
    {
      "name": "TaskCreateForm",
      "description": "Formulier om een nieuwe AI-taak aan te maken.",
      "file": "components/TaskCreateForm.tsx",
      "usedOn": [
        "app/dashboard/tasks/page.tsx"
      ]
    }
  ],
  "stateManagement": {
    "strategy": "React context voor gebruikersauthenticatie en session state, lokale component state voor formulieren en UI.",
    "notes": "Session context wordt gebruikt om de ingelogde gebruiker en sessie te beheren. Voor taken en profiel wordt fetch/async gebruikt met SWR of React hooks."
  },
  "dataLayer": {
    "strategy": "In-memory store (singleton pattern) voor gebruikers, sessies en taken.",
    "notes": "Alle data wordt in-memory opgeslagen (bv. in een Map of array in een module). Voor productie kan eenvoudig een database worden aangesloten."
  }
}