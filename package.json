{
  "name": "ai-app-saas-monorepo",
  "private": true,
  "workspaces": [
    "frontend",
    "backend",
    "shared",
    "infra"
  ],
  "scripts": {
    "dev": "concurrently \"npm:start --prefix backend\" \"npm:start --prefix frontend\"",
    "build": "npm:build --workspaces",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "jest"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "eslint": "^8.0.0",
    "jest": "^29.0.0",
    "concurrently": "^8.0.0"
  },
  "dependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "express": "^4.18.0"
  }
}
