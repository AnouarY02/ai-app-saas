{
  "name": "ai-app-saas",
  "private": true,
  "workspaces": [
    "frontend",
    "backend",
    "shared"
  ],
  "scripts": {
    "dev": "concurrently \"npm:start --prefix backend\" \"npm:start --prefix frontend\"",
    "build": "npm run build --workspaces",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write .",
    "start": "node backend/dist/server.js"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "eslint": "^8.0.0",
    "prettier": "^2.8.0",
    "ts-node": "^10.0.0",
    "concurrently": "^8.0.0"
  }
}
