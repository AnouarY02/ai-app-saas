{
  "name": "ai-app-saas-monorepo",
  "private": true,
  "workspaces": [
    "frontend",
    "backend",
    "shared",
    "infra"
  ],
  "scripts": {
    "dev": "concurrently \"npm:start --prefix backend\" \"npm:start --prefix frontend\"",
    "build": "npm run build --workspaces",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write .",
    "start:frontend": "vite --host",
    "start:backend": "ts-node backend/src/server.ts",
    "deploy": "ts-node infra/scripts/deploy.ts"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "eslint": "^8.0.0",
    "prettier": "^2.8.0",
    "ts-node": "^10.0.0",
    "nodemon": "^2.0.0",
    "concurrently": "^8.0.0"
  },
  "dependencies": {
    "vite": "^4.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "express": "^4.18.0",
    "dotenv": "^16.0.0"
  }
}
