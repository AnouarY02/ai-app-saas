{
  "name": "saas-crm-monorepo",
  "private": true,
  "workspaces": [
    "frontend",
    "backend",
    "shared"
  ],
  "scripts": {
    "dev": "concurrently \"npm:start --prefix backend\" \"npm:start --prefix frontend\"",
    "build": "npm run build --workspaces",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "jest",
    "start": "node backend/dist/server.js"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "eslint": "^8.0.0",
    "prettier": "^2.8.0",
    "jest": "^29.0.0",
    "concurrently": "^8.0.0",
    "cross-env": "^7.0.0"
  },
  "dependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "redux": "^4.2.0",
    "@reduxjs/toolkit": "^1.9.0",
    "react-redux": "^8.0.0",
    "axios": "^1.3.0",
    "express": "^4.18.0",
    "jsonwebtoken": "^9.0.0",
    "bcryptjs": "^2.4.3",
    "zod": "^3.20.0",
    "dotenv": "^16.0.0",
    "cors": "^2.8.5",
    "morgan": "^1.10.0"
  }
}
